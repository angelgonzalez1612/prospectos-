{
  "name": "prospect-finder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start:server": "npm install --prefix server && npm start --prefix server",
    "dev:all": "concurrently \"vite\" \"npm start --prefix server\"",
    "build:render": "npm install --include=dev && npm run build && npm install --prefix server",
    "start:render": "node server/index.js"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.19.3",
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.3.1"
  }
}
